# Backend
DB_HOST=aws-0-eu-west-3.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-password
DATABASE_URL=postgresql://postgres.your-project-ref:password@host:6543/postgres

JWT_PRIVATE_KEY_B64=base64-encoded-rsa-private-key
JWT_PUBLIC_KEY_B64=base64-encoded-rsa-public-key

ENV=production
PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Optional
REDIS_URL=
B2_BUCKET=
B2_KEY_ID=
B2_APP_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend
VITE_API_URL=https://your-backend.up.railway.app